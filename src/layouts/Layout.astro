---
type Props = {
  title?: string;
  description?: string;
  ogImage?: string; // e.g. "/og.png" or "/profile.jpg"
  noindex?: boolean;
};

const {
  title = "Gibeom Kim",
  description = "Personal website of Gibeom Kim.",
  ogImage = "/og.png",
  noindex = false,
} = Astro.props;

const site = Astro.site;

// Base-path helper (GitHub Pages repo site support)
const RAW_BASE = import.meta.env.BASE_URL ?? "/";
const BASE = RAW_BASE.endsWith("/") ? RAW_BASE : `${RAW_BASE}/`;
const withBase = (p: string) => `${BASE}${String(p).replace(/^\/+/, "")}`;

const canonical = site ? new URL(Astro.url.pathname, site).toString() : undefined;

const isAbsoluteUrl = (u: string) => /^https?:\/\//i.test(u);

// Ensure OG image points to the correct base path
const ogPath = isAbsoluteUrl(ogImage) ? ogImage : withBase(ogImage);
const ogAbs = site ? new URL(ogPath, site).toString() : ogPath;

// JSON-LD (Person)
const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Gibeom Kim",
  url: site ? new URL(BASE, site).toString() : undefined,
  sameAs: [
    "https://github.com/Gibeom-KIM-02",
    "https://www.linkedin.com/in/gibeom-kim-0bbb68370/",
  ],
  affiliation: {
    "@type": "CollegeOrUniversity",
    name: "UNIST",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content="#0b1020" />

    <!-- Favicon -->
    <link rel="icon" href={withBase("favicon.png")} type="image/png" sizes="32x32" />
    <link rel="icon" href={withBase("favicon.png")} type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href={withBase("favicon.png")} />

    {canonical && <link rel="canonical" href={canonical} />}

    {noindex ? (
      <meta name="robots" content="noindex,nofollow" />
    ) : (
      <meta name="robots" content="index,follow" />
    )}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Gibeom Kim" />
    <meta property="og:locale" content="en_US" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={ogAbs} />
    <meta property="og:image:alt" content="Gibeom Kim personal website preview" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogAbs} />
    <meta name="twitter:image:alt" content="Gibeom Kim personal website preview" />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {JSON.stringify(personJsonLd)}
    </script>
  </head>

  <body>
    <main class="container">
      <slot />
    </main>
  </body>
</html>

<style>
  html, body { margin: 0; width: 100%; height: 100%; }
  * { box-sizing: border-box; }

  body {
    font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, "Helvetica Neue", Arial, "Noto Sans", "Apple Color Emoji", "Segoe UI Emoji";
    line-height: 1.5;
    color: #111;
    background: #fff;
  }

  .container{
    max-width: 1110px;
    margin: 0 auto;
    padding: 36px 22px;
  }
</style>
