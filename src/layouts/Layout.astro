---
type Props = {
  title?: string;
  description?: string;
  ogImage?: string;   // e.g. "/og.png" or "/projects/profile.jpg"
  noindex?: boolean;
};

const {
  title = "Gibeom Kim",
  description = "Personal website of Gibeom Kim.",
  ogImage = "/projects/profile.jpg",  // 일단 프로필 사진으로 기본값
  noindex = false,
} = Astro.props;

const site = Astro.site; // astro.config.mjs의 site 값 사용
const canonical = site ? new URL(Astro.url.pathname, site).toString() : undefined;
const ogAbs = site ? new URL(ogImage, site).toString() : ogImage;

// JSON-LD (Person) - 필요하면 수정
const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Gibeom Kim",
  url: canonical ? new URL("/", canonical).toString() : undefined,
  sameAs: [
    "https://github.com/Gibeom-KIM-02",
  ],
  affiliation: {
    "@type": "CollegeOrUniversity",
    name: "UNIST",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    {canonical && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={ogAbs} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogAbs} />

    {/* Structured Data */}
    <script type="application/ld+json">
      {JSON.stringify(personJsonLd)}
    </script>
  </head>

  <body>
    <main class="container">
      <slot />
    </main>
  </body>
</html>

<style>
  html, body { margin: 0; width: 100%; height: 100%; }

  .container{
    max-width: 1110px;      /* 페이지 최대 폭 */
    margin: 0 auto;        /* 가운데 정렬 */
    padding: 36px 22px;    /* 상하 28px, 좌우 18px 여백 */
  }
</style>
