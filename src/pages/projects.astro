---
import Layout from "../layouts/Layout.astro";
import { projects } from "../data/projects";

// Base-path helper (GitHub Pages repo site support)
const RAW_BASE = import.meta.env.BASE_URL ?? "/";
const BASE = RAW_BASE.endsWith("/") ? RAW_BASE : `${RAW_BASE}/`;
const withBase = (p: string) => `${BASE}${String(p).replace(/^\/+/, "")}`;

function detailsPath(p: any): string {
  if (p?.slug) return `projects/${p.slug}/`;

  const t = String(p?.title ?? "").toLowerCase();
  if (t.includes("lammps input generator")) return "projects/lammps-input-generator/";
  if (t.includes("bandgap") && t.includes("cgcnn")) return "projects/bandgap-cgcnn/";
  if (t.includes("hartree") || t.includes("fock")) return "projects/hf/";
  return "projects/";
}
---

<Layout title="Projects - Gibeom Kim" description="Projects by Gibeom Kim.">
  <a class="back" href={withBase("")}>Back to Home</a>

  <header class="hero">
    <div class="titleRow">
      <h1>Projects</h1>
      <span class="muted">{projects.length} items</span>
    </div>
    <p class="lead">
      A list of projects and reproducible workflows I have built or contributed to.
    </p>
  </header>

  <section class="grid">
    {projects.map((p) => (
      <article class="card">
        <div class="cardTop">
          <h2>{p.title}</h2>
          <span class="muted">{p.period ?? ""}</span>
        </div>

        <p class="muted">{p.oneLiner}</p>

        <div class="tags">
          {p.tags?.slice(0, 5).map((t) => <span class="pill">{t}</span>)}
        </div>

        <div class="btns">
          <a class="btn primary" href={withBase(detailsPath(p))}>Details</a>
          {p.links?.github && (
            <a class="btn" href={p.links.github} target="_blank" rel="noreferrer">GitHub</a>
          )}
        </div>
      </article>
    ))}
  </section>

  <style>
    .back { display:inline-block; margin: 8px 0 18px; text-decoration:none; font-size: 13px; opacity: .8; }
    .back:hover { text-decoration: underline; }

    .hero { padding: 6px 0 18px; }
    .titleRow { display:flex; justify-content: space-between; gap: 12px; flex-wrap: wrap; align-items: baseline; }

    h1 { margin: 0; font-size: 26px; letter-spacing: -0.02em; }
    h2 { margin: 0; font-size: 16px; }

    .lead { margin: 10px 0 0; max-width: 80ch; opacity: .85; }
    .muted { opacity: .75; font-size: 13px; margin: 6px 0; }

    .grid { display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; }

    @media (max-width: 980px){
      .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 640px){
      .grid { grid-template-columns: 1fr; }
    }

    .card { border: 1px solid rgba(0,0,0,0.06); border-radius: 14px; padding: 14px; background: #fff; }
    .cardTop { display:flex; justify-content: space-between; gap: 10px; align-items: baseline; flex-wrap: wrap; }

    .tags { display:flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
    .pill { font-size: 12px; border: 1px solid rgba(0,0,0,0.08); padding: 4px 8px; border-radius: 999px; opacity: 0.85; }

    .btns { display:flex; gap: 10px; flex-wrap: wrap; margin-top: 12px; }
    .btn { border: 1px solid #ddd; padding: 10px 12px; border-radius: 10px; text-decoration: none; font-size: 14px; }
    .btn.primary { background: #111; color: #fff; border-color: #111; }
  </style>
</Layout>
