---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Gibeom Kim" description="Page not found." noindex={true}>
  <main class="wrap">
    <h1>404</h1>
    <p class="muted">Page not found.</p>
    <a class="btn" href="/">Go home</a>
  </main>

  <style>
    .wrap { max-width: 900px; margin: 0 auto; padding: 48px 18px; }
    .muted { opacity: .75; }
    .btn { display:inline-block; margin-top: 12px; border: 1px solid #ddd; padding: 10px 12px; border-radius: 10px; text-decoration: none; }
  </style>
</Layout>
