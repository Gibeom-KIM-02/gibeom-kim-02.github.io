---
import Layout from "../../layouts/Layout.astro";

const title = "Packmol Runner";
const period = "2025";
const tags = ["Packmol", "ASE", "LAMMPS", "Automation", "Reproducibility"];
const repo = "https://github.com/Gibeom-KIM-02/packmol_runner";

const RAW_BASE = import.meta.env.BASE_URL ?? "/";
const BASE = RAW_BASE.endsWith("/") ? RAW_BASE : `${RAW_BASE}/`;
const withBase = (p) => `${BASE}${String(p).replace(/^\/+/, "")}`;

// Put the file here: public/projects/packmol-runner.jpg
const heroImage = withBase("projects/packmol-runner.jpg");
---

<Layout title={`${title} - Gibeom Kim`} description="A YAML-driven workflow to build molecular simulation starting structures using Packmol and ASE.">
  <a class="back" href={withBase("projects/")}>Back to Projects</a>

  <header class="hero">
    <div class="titleRow">
      <h1>{title}</h1>
      <span class="muted">{period}</span>
    </div>

    <div class="tags">
      {tags.map((t) => <span class="pill">{t}</span>)}
    </div>

    <p class="lead">
      A reproducible workflow for generating initial molecular simulation structures using
      Packmol and ASE. The project is designed to reduce repetitive manual setup and make
      packing workflows easier to reuse across different systems.
    </p>

    <div class="btns">
      <a class="btn primary" href={repo} target="_blank" rel="noreferrer">GitHub</a>
    </div>
  </header>

  <section class="sec">
    <h2>What it does</h2>
    <div class="card">
      <ul class="muted list">
        <li>Builds initial coordinates for bulk and slab-based simulation systems.</li>
        <li>Uses YAML-driven configuration to control composition and workflow behavior.</li>
        <li>Combines Packmol and ASE to make structure generation more reproducible and easier to automate.</li>
      </ul>
    </div>
  </section>

  <section class="sec">
    <h2>My role</h2>
    <div class="card">
      <p class="muted">
        Designed the repository structure, organized the configuration-based workflow,
        and developed a reusable pipeline for generating simulation-ready structures
        across multiple use cases.
      </p>
    </div>
  </section>

  {heroImage ? (
    <section class="sec">
      <h2>Figure</h2>
      <div class="imgWrap">
        <img src={heroImage} alt="Packmol Runner figure" loading="lazy" />
      </div>
    </section>
  ) : null}

  <section class="sec">
    <h2>How to run</h2>
    <div class="card">
      <pre><code>git clone {repo}
cd packmol_runner</code></pre>
      <p class="muted" style="margin-top:10px;">
        See the repository README for environment setup, YAML configuration, and workflow-specific commands.
      </p>
    </div>
  </section>

  <style>
    .back { display:inline-block; margin: 8px 0 18px; text-decoration:none; font-size: 13px; opacity: .8; }
    .back:hover { text-decoration: underline; }

    .hero { padding: 6px 0 18px; }
    .titleRow { display:flex; justify-content: space-between; gap: 12px; flex-wrap: wrap; align-items: baseline; }

    h1 { margin: 0; font-size: 26px; letter-spacing: -0.02em; }
    h2 { margin: 0 0 10px; font-size: 18px; }

    .lead { margin: 10px 0 0; max-width: 80ch; opacity: .85; }
    .muted { opacity: .75; font-size: 13px; margin: 6px 0; }

    .btns { display:flex; gap: 10px; flex-wrap: wrap; margin-top: 14px; }
    .btn { border: 1px solid #ddd; padding: 10px 12px; border-radius: 10px; text-decoration: none; font-size: 14px; }
    .btn.primary { background: #111; color: #fff; border-color: #111; }

    .sec { padding: 16px 0; }
    .card { border: 1px solid #e7e7e7; border-radius: 14px; padding: 14px; background: #fff; }

    .tags { display:flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
    .pill { font-size: 12px; border: 1px solid #eee; padding: 4px 8px; border-radius: 999px; opacity: .85; }

    .list { margin: 8px 0 0; padding-left: 18px; }
    .list li { margin: 6px 0; }

    pre { margin: 8px 0 0; padding: 10px 12px; border-radius: 12px; background: #fafafa; border: 1px solid #eee; overflow:auto; }
    code { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace; font-size: 12px; }

    .imgWrap { border: 1px solid #e7e7e7; border-radius: 14px; overflow: hidden; background: #fff; }
    .imgWrap img { width: 100%; height: auto; display:block; }
  </style>
</Layout>